{
  "name": "@molin05831/storymaker",
  "version": "0.1.0",
  "private": false,
  "description": "StoryMaker command line interface for local-first narrative engineering workflows.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "storymaker": "dist/index.js",
    "storyctl": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "node ../../scripts/build-cli-package.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}
