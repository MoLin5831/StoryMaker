{
  "name": "storymaker-root",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "StoryMaker 是面向长上下文 AI 辅助创作的本地优先叙事工程运行时。",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "corepack pnpm build:dashboard && corepack pnpm -r --filter \"./packages/*\" typecheck",
    "build:cli-runtime": "node scripts/build-cli-runtime.mjs",
    "build:dashboard": "corepack pnpm --filter ./packages/cli build && corepack pnpm --filter ./apps/dashboard build",
    "format": "biome format --write package.json biome.json vitest.config.ts",
    "lint": "biome lint .",
    "package:binaries": "node scripts/package-binaries.mjs",
    "package:cli-smoke": "node scripts/verify-cli-package.mjs",
    "release:check": "node scripts/release-check.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "security:audit": "corepack pnpm audit --audit-level high",
    "storymaker": "node scripts/ensure-cli-runtime.mjs && tsx packages/cli/src/index.ts",
    "storyctl": "node scripts/ensure-cli-runtime.mjs && tsx packages/cli/src/index.ts",
    "typecheck": "tsc --version && node -e \"JSON.parse(require('node:fs').readFileSync('tsconfig.base.json', 'utf8')); console.log('tsconfig.base.json OK')\"",
    "test": "corepack pnpm build:dashboard && corepack pnpm -r --filter \"./packages/*\" --filter \"./apps/*\" test",
    "verify:clean-source": "node scripts/verify-clean-source.mjs"
  },
  "bin": {
    "storymaker": "./bin/storymaker",
    "storyctl": "./bin/storyctl"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "@storyos/adapters-claude": "link:packages/adapters-claude",
      "@storyos/adapters-codex": "link:packages/adapters-codex",
      "@storyos/core": "link:packages/core",
      "@storyos/exporters": "link:packages/exporters",
      "@storyos/indexer": "link:packages/indexer",
      "@storyos/knowledge": "link:packages/knowledge",
      "@storyos/schemas": "link:packages/schemas",
      "@storyos/workflow-engine": "link:packages/workflow-engine"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "10.17.1"
  }
}
